config tang 'tang'
	option enabled '1'
	# Port to serve Tang on. NOT 80 (LuCI/uhttpd uses that on OpenWrt).
	option port '7500'
	# Bind address; 0.0.0.0 = all interfaces. Restrict to the LAN if desired.
	option address '0.0.0.0'
	# Key directory (tangd-keygen output). MUST be persistent: on OpenWrt
	# /var -> /tmp is tmpfs, so keys there are WIPED on every reboot (the
	# service then won't start and clevis clients can't unlock). /etc is on
	# the overlay and survives reboot; keys here are also kept across
	# sysupgrade via /lib/upgrade/keep.d/tang.
	option keydir '/etc/tang'
